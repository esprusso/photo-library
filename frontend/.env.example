# Frontend Configuration for GIF Library

# Legacy Configuration
VITE_ENABLE_SMART_TAG=false

# API Configuration
VITE_API_BASE_URL=http://localhost:8000

# Thumbnail and Preview Configuration
VITE_HOVER_PRELOAD_DELAY_MS=100
VITE_ENABLE_3X_DPR=false

# UI Features
VITE_HIDE_MEMORIES=true
VITE_DEFAULT_GRID_SIZE=medium

# Performance Settings
VITE_LAZY_LOAD_THRESHOLD=0.1
VITE_LAZY_LOAD_ROOT_MARGIN=50px

# Development
VITE_DEBUG_PERFORMANCE=false

