# Core Configuration  
LIBRARY_PATHS=/library,/clips

# Docker Volume Configuration
# Set this to the path on your host where your photos are stored
# For your Spicy Gif Library: LIBRARY_HOST_PATH="/volume1/homes/rheritage/Spicy Gif Library"
# For other Synology folders: LIBRARY_HOST_PATH=/volume1/photos
# For other systems: LIBRARY_HOST_PATH=/path/to/your/photos
LIBRARY_HOST_PATH="/volume1/homes/rheritage/Spicy Gif Library"

# Set this to the path on your host where your video clips are stored
CLIPS_HOST_PATH="/volume1/homes/rheritage/Spicy Clip Library"
DB_URL=sqlite:///data/app.db
THUMBNAILS_DIR=/thumbnails
DOWNLOADS_DIR=/downloads
MEDIA_DIR=/data/media

# Thumbnail Generation
THUMBNAIL_SIZE=256
THUMBNAIL_SCALE=2
ENABLE_3X_DPR=false

# Animated Preview Configuration
ANIMATED_PREVIEW_FORMAT=auto
HOVER_PRELOAD_DELAY_MS=100

# Performance & Features
ENABLE_FFMPEG_FALLBACK=false
HIDE_MEMORIES=true

# Time Zone
TZ=Etc/UTC

# Optional Security (for production deployments)
# SECRET_KEY=your-secret-key
# ALLOWED_HOSTS=localhost,127.0.0.1